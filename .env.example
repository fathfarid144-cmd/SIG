# ============================================================
# Environment Configuration
# Sistem Monitoring Kecelakaan Lalu Lintas - Lampung Selatan
# ============================================================

# --- Database PostgreSQL + PostGIS ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kecelakaan_lampsel_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# URL koneksi lengkap (otomatis dibentuk dari variabel di atas)
# DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/kecelakaan_lampsel_db

# --- Aplikasi ---
APP_NAME="Sistem Monitoring Kecelakaan Lalu Lintas Lampung Selatan"
APP_VERSION="1.0.0"
DEBUG=True

# --- CORS (Frontend URL) ---
FRONTEND_URL=http://localhost:5173
